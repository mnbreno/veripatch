{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VeriPatch release consensus",
  "type": "object",
  "required": ["schema_version", "project", "version", "consensus"],
  "properties": {
    "schema_version": { "const": "1" },
    "project": { "const": "veripatch" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generated_at": { "type": "string" },
    "workflow": { "type": "string" },
    "correlation_id": { "type": "string" },
    "consensus": {
      "type": "object",
      "required": ["approved", "production_ready", "agents"],
      "properties": {
        "approved": { "const": true },
        "production_ready": { "const": true },
        "blockers": { "type": "array", "maxItems": 0 },
        "summary": { "type": "string" },
        "agents": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["agent_id", "verdict"],
            "properties": {
              "agent_id": { "type": "string" },
              "verdict": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
